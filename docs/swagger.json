        "/auth/github": {
            "get": {
                "description": "GitHub OAuth 인증 페이지로 리다이렉트합니다. OAUTH_STATE 쿠키가 발급됩니다.",
                "tags": [
                    "auth"
                ],
                "summary": "GitHub OAuth 로그인 시작",
                "responses": {
                    "302": {
                        "description": "Found"
